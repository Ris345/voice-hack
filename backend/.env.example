# Copy to .env and fill in. NEVER commit .env.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Twilio (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Optional: separate SMS-capable number for alert/digest texts.
# Leave empty to send SMS from TWILIO_FROM_NUMBER (needs a voice+SMS number).
TWILIO_SMS_NUMBER=

# Public URL of THIS backend (ngrok/cloudflared tunnel) — Twilio must reach it
# Run with: uvicorn app.main:app --port 8080   (voice-agent owns 8000)
PUBLIC_BASE_URL=https://your-tunnel.ngrok-free.app

# TwiML URL for the voice agent (teammate's endpoint).
# Leave empty to use the built-in placeholder at /twilio/voice.
VOICE_AGENT_TWIML_URL=
